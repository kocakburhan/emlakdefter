# Application Settings
APP_NAME="Emlakdefter SaaS Platform"
DEBUG=True
API_V1_STR="/api/v1"

# Database Settings (Docker: emlakdefter_user / emlakdefter_password)
DATABASE_URL="postgresql+asyncpg://emlakdefter_user:emlakdefter_password@127.0.0.1:5433/emlakdefter"
SYNC_DATABASE_URL="postgresql://emlakdefter_user:emlakdefter_password@127.0.0.1:5433/emlakdefter"

# Redis Integration
REDIS_URL="redis://localhost:6379/0"

# Security (JWT & Token Auth)
SECRET_KEY="generate_a_highly_secure_random_key_for_this_project"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI/LLM Integration (Gemini)
GEMINI_API_KEY="your_gemini_api_key_here"

# Firebase Credentials Path
FIREBASE_CREDENTIALS_PATH="firebase-adminsdk.json"

# Hetzner Object Storage (S3-compatible) — PRD §4.1.8-C
# Get credentials from: https://console.hetzner.cloud/projects → Storage → Buckets
HETZNER_ACCESS_KEY="your_hetzner_access_key_here"
HETZNER_SECRET_KEY="your_hetzner_secret_key_here"
HETZNER_ENDPOINT="https://fra1.digitaloceanspaces.com"
HETZNER_BUCKET="emlakdefter-media"
HETZNER_REGION="eu-central"
# CDN base URL (public read): https://{bucket}.{endpoint}
HETZNER_CDN_BASE="https://emlakdefter-media.fra1.digitaloceanspaces.com"
