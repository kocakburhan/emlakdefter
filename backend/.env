# Application Settings
APP_NAME="Emlakdefteri SaaS Platform"
DEBUG=True
API_V1_STR="/api/v1"

# Database Settings (Docker: emlakdefteri_user / emlakdefteri_password)
DATABASE_URL="postgresql+asyncpg://emlakdefteri_user:emlakdefteri_password@127.0.0.1:5433/emlakdefteri"
SYNC_DATABASE_URL="postgresql://emlakdefteri_user:emlakdefteri_password@127.0.0.1:5433/emlakdefteri"

# Redis Integration
REDIS_URL="redis://localhost:6379/0"

# Security (JWT & Token Auth)
SECRET_KEY="generate_a_highly_secure_random_key_for_this_project"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI/LLM Integration (Gemini)
GEMINI_API_KEY="your_gemini_api_key_here"

# Firebase Credentials Path
FIREBASE_CREDENTIALS_PATH="emlakdefter-firebase-adminsdk-fbsvc-d151ece696.json"
