# Emlakdefter Production Environment Variables
# Copy this to /opt/emlakdefter/backend/.env and fill in real values

# ── Database ──────────────────────────────────────────────────────────────
# PostgreSQL URL (used by Docker Compose)
# Default from docker-compose.prod.yml:
#   postgresql+asyncpg://emlakdefter_user:emlakdefter_password@db:5432/emlakdefter
# For local development, use:
#   postgresql+asyncpg://emlakdefter_user:emlakdefter_password@localhost:5433/emlakdefter
DATABASE_URL=postgresql+asyncpg://emlakdefter_user:emlakdefter_password@db:5432/emlakdefter

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Security ─────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Firebase Admin SDK ────────────────────────────────────────────────────
# Path to firebase-adminsdk.json on the server
FIREBASE_CREDENTIALS_PATH=/opt/emlakdefter/backend/firebase-adminsdk.json

# ── Gemini AI ─────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Hetzner Object Storage (S3-compatible) ───────────────────────────────
# Get credentials from: https://console.hetzner.cloud → Storage → Buckets
HETZNER_ACCESS_KEY=your_hetzner_access_key_here
HETZNER_SECRET_KEY=your_hetzner_secret_key_here
HETZNER_ENDPOINT=https://hel1.your-objectstorage.com
HETZNER_BUCKET=emlakdefter-media
HETZNER_REGION=hel1
HETZNER_CDN_BASE=https://emlakdefter-media.hel1.your-objectstorage.com

# ── Environment ──────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false

# ── CORS (restrict to your domains in production) ─────────────────────────
# CORS_ORIGINS=https://emlakdefter.com,https://www.emlakdefter.com
